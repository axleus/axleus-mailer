{
    "name": "axleus/axleus-mailer",
    "description": "Php Mail abstraction for a variety of php mailer libraries for mezzio applications",
    "license": "BSD-3-Clause",
    "keywords": [
        "axleus",
        "mezzio",
        "php mail",
        "MailerInterface abstraction for mezzio applications"
    ],
    "homepage": "https://github.com/orgs/axleus/discussions",
    "support": {
        "issues": "https://github.com/axleus/axleus-mailer/issues",
        "chat": "https://discord.gg/9TxQ74EPsG"
    },
    "authors": [
        {
            "name": "Joey Smith",
            "email": "jsmith@webinertia.net"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../../webware/*"
        }
    ],
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "phpmailer/phpmailer": "^7.0.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5.42",
        "psr/http-message": "^1.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-server-middleware": "^1.0",
        "roave/security-advisories": "dev-master",
        "webware/coding-standard": "^0.1.0",
        "webware/command-bus": "0.4.0",
        "webware/commandbus-event": "^0.1.0"
    },
    "extra": {
        "laminas": {
            "config-provider": "Axleus\\Mailer\\ConfigProvider"
        }
    },
    "autoload": {
        "psr-4": {
            "Axleus\\Mailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AxleusTest\\Mailer\\": "test/"
        }
    },
    "scripts": {
        "check": [
            "@cs-check",
            "@sa",
            "@test",
            "@test-integration"
        ],
        "cs-check": "vendor/bin/php-cs-fixer check -v --show-progress=dots --stop-on-violation",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "test": "phpunit --colors=always --testsuite \"unit test\"",
        "test-coverage": "phpunit --colors=always --coverage-clover clover.xml",
        "test-integration": "phpunit --colors=always --testsuite \"integration test\"",
        "sa": "vendor/bin/phpstan analyse --memory-limit=256M",
        "sa-gen-baseline": "vendor/bin/phpstan analyse --memory-limit=256M --generate-baseline",
        "sa-verbose": "vendor/bin/phpstan analyse --memory-limit=256M -vv",
        "upload-coverage": "coveralls -v"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.99"
        },
        "allow-plugins": {
            "laminas/laminas-component-installer": true,
            "composer/package-versions-deprecated": true
        }
    }
}
